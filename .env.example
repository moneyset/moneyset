# MONEYSET — environment template (copy to .env.local; never commit secrets)

# ─── Public site (SITE_URL preferred; APP_URL accepted as alias) ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Optional: dedicated secret for Telegram auth password derivation (falls back to service role)
TELEGRAM_AUTH_SECRET=

# ─── Market data ───
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
COINGECKO_API_KEY=
COINALYZE_API_KEY=
FRED_API_KEY=
TRADINGVIEW_SYMBOL=BINANCE:BTCUSDT

# ─── AI (server-side only) ───
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=openai/gpt-4o-mini
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_ORCHESTRATOR=openai/gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ─── Payments (NOWPayments — server-side) ───
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_URL=
NOWPAYMENTS_IPN_SECRET=

# ─── Cron / ops ───
CRON_SECRET=
