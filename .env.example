# MONEYSET — environment template (copy to .env.local; never commit secrets)

# ─── Public site (SITE_URL preferred; APP_URL accepted as alias) ───
# Production: https://moneyset.pro
NEXT_PUBLIC_SITE_URL=https://moneyset.pro
# Local dev only:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URI — required only for scripts/apply-core-schema.mjs or POST /api/cron/bootstrap-schema
# Supabase Dashboard → Project Settings → Database → Connection string (URI)
# DATABASE_URL=
# SUPABASE_DB_URL=

# Optional: Supabase Management API personal access token (Account → Access Tokens)
# Enables `npm run apply:schema` without database password
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# ─── Telegram ───
# Set to true to enable bot webhook, state push, and alert delivery (off by default).
MONEYSET_TELEGRAM_ENABLED=false
NEXT_PUBLIC_MONEYSET_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# BotFather Mini App short name (Direct Link), e.g. moneyset → t.me/BotName/moneyset
NEXT_PUBLIC_TELEGRAM_MINI_APP_NAME=moneyset
TELEGRAM_WEBHOOK_SECRET=
# Required in production — dedicated secret for Telegram auth password derivation (never reuse bot token)
TELEGRAM_AUTH_SECRET=
# BotFather → Bot Settings → Web Login (OIDC) — switch from legacy widget
TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
# Public client id for browser login button (same numeric id as TELEGRAM_OIDC_CLIENT_ID)
NEXT_PUBLIC_TELEGRAM_OIDC_CLIENT_ID=

# ─── Market data ───
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
COINGECKO_API_KEY=
COINALYZE_API_KEY=
FRED_API_KEY=
TRADINGVIEW_SYMBOL=BINANCE:BTCUSDT

# ─── AI (server-side only) ───
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=openai/gpt-4o-mini
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_ORCHESTRATOR=openai/gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ─── Payments (NOWPayments — server-side) ───
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_URL=
NOWPAYMENTS_IPN_SECRET=

# ─── Cron / ops ───
CRON_SECRET=
